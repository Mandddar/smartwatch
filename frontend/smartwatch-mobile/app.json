{
  "expo": {
    "name": "VitalWatch",
    "slug": "smartwatch-mobile",
    "version": "1.0.0-beta.1",
    "scheme": "smartwatch",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3509c17c-3c4d-4333-a8b7-5778acefe308"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      "expo-updates",
      "expo-background-fetch",
      "expo-task-manager"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "3509c17c-3c4d-4333-a8b7-5778acefe308"
      }
    },
    "android": {
      "package": "com.invincible1.smartwatchmobile",
      "versionCode": 2,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.invincible1.smartwatchmobile",
      "supportsTablet": true
    }
  }
}
